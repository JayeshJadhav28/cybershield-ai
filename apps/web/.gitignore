# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ── ML Models & Datasets (must NEVER be bundled in the frontend) ──────────────
# All inference happens via the backend API — see src/lib/api.ts
*.pt
*.pkl
*.h5
*.onnx
*.bin
*.safetensors
*.npy
*.npz
models/
data/
datasets/
