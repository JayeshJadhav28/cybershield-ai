# ═══════════════════════════════════════════
# CyberShield AI — Environment Configuration
# ═══════════════════════════════════════════

# ── Database ──
DATABASE_URL=postgresql://cybershield:cybershield_pass@localhost:5432/cybershield_db

# ── Auth ──
JWT_SECRET=change-this-to-a-random-64-char-string-in-production-abcdef123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
OTP_EXPIRE_MINUTES=5

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000"]

# ── File Uploads ──
UPLOAD_DIR=/tmp/cybershield_uploads
MAX_AUDIO_SIZE_MB=10
MAX_VIDEO_SIZE_MB=50
MAX_IMAGE_SIZE_MB=5
MAX_AUDIO_DURATION_S=30
MAX_VIDEO_DURATION_S=60

# ── Models ──
MODEL_DIR=./models

# ── Scoring Defaults ──
SAFE_THRESHOLD=30
DANGEROUS_THRESHOLD=70

# ── Email (OTP Delivery) ──
Production: uncomment and configure
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@cybershield.ai

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1


# ── LLM (if using chatbot) ──
GROQ_API_KEY=
OPENAI_API_KEY=
